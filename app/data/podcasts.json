[{"id":"ep1","title":"تعلم التركية - المبتدئون - التحيات","youtubeId":"7GKmESyFHgQ","level":"B1","topic":"تحيات","durationMin":8,"transcript":[{"time":0,"tr":"Merhaba! Bugün Türkçe öğreneceğiz.","ar":"مرحباً! سنتعلم التركية اليوم.","en":"Hello! Today we will learn Turkish."},{"time":5,"tr":"İlk olarak selamlaşmayı öğrenelim.","ar":"أولاً لنتعلم التحية.","en":"First, let us learn greetings."},{"time":10,"tr":"Merhaba nasılsın?","ar":"مرحباً، كيف حالك؟","en":"Hello, how are you?"},{"time":15,"tr":"İyiyim teşekkür ederim, ya sen?","ar":"بخير شكراً، وأنت؟","en":"I am fine thank you, and you?"},{"time":20,"tr":"Ben de iyiyim.","ar":"أنا بخير أيضاً.","en":"I am fine too."},{"time":25,"tr":"Günaydın demek sabah için.","ar":"صباح الخير تقال في الصباح.","en":"Günaydın means good morning."},{"time":30,"tr":"İyi akşamlar demek akşam için.","ar":"مساء الخير تقال في المساء.","en":"İyi akşamlar means good evening."}]},{"id":"ep2","title":"الأفعال الأساسية في التركية","youtubeId":"ZeZDZmhvSME","level":"B1","topic":"أفعال","durationMin":12,"transcript":[{"time":0,"tr":"Bugün temel fiilleri öğreneceğiz.","ar":"سنتعلم اليوم الأفعال الأساسية.","en":"Today we will learn basic verbs."},{"time":6,"tr":"Gitmek: gidiyorum, gidiyorsun, gidiyor.","ar":"يذهب: أذهب، تذهب، يذهب.","en":"To go: I go, you go, he goes."},{"time":12,"tr":"Yemek: yiyorum, yiyorsun, yiyor.","ar":"يأكل: آكل، تأكل، يأكل.","en":"To eat: I eat, you eat, he eats."},{"time":18,"tr":"İçmek: içiyorum, içiyorsun, içiyor.","ar":"يشرب: أشرب، تشرب، يشرب.","en":"To drink: I drink, you drink, he drinks."}]},{"id":"ep3","title":"التركية B2 - الجمل الشرطية","youtubeId":"dQw4w9WgXcQ","level":"B2","topic":"قواعد","durationMin":15,"transcript":[{"time":0,"tr":"Şart cümlelerini öğrenelim.","ar":"لنتعلم الجمل الشرطية.","en":"Let us learn conditional sentences."},{"time":8,"tr":"Eğer gidersen, beni ara.","ar":"إذا ذهبت، اتصل بي.","en":"If you go, call me."},{"time":16,"tr":"Eğer yağmur yağarsa, içeride kalacağım.","ar":"إذا أمطرت، سأبقى في الداخل.","en":"If it rains, I will stay inside."}]}]
